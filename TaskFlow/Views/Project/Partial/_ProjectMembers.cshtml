@model TaskFlow.ViewModels.Project.ProjectDetailsVM

<div class="card shadow-sm border-0 mt-4">

    <div class="card-header bg-white">

        <div class="d-flex justify-content-between align-items-start">

            <div>

                <h5 class="mb-1">
                    <i class="bi bi-people-fill me-2"></i>
                    Project Members
                </h5>

                <div class="d-flex flex-wrap gap-3 mt-2">

                    <span class="badge bg-primary">
                        @Model.MemberCount Members
                    </span>

                    <span class="badge bg-success">
                        @Model.BillableMemberCount Billable
                    </span>

                    <span class="badge bg-secondary">
                        @Model.NonBillableMemberCount Non-Billable
                    </span>

                </div>

            </div>

            <a asp-controller="ProjectMember"
               asp-action="AddMember"
               asp-route-projectId="@Model.ProjectId"
               class="btn btn-primary">

                <i class="bi bi-plus-lg me-1"></i>

                Add Member

            </a>

        </div>

    </div>
    <div class="card-body">
        @if (!Model.Members.Any())
        {
            <div class="text-center py-5">

                <i class="bi bi-people fs-1 text-muted"></i>

                <h5 class="mt-3">
                    No project members
                </h5>

                <p class="text-muted">
                    Start building your team by adding the first project member.
                </p>

                <a asp-controller="Project"
                   asp-action="AddMember"
                   asp-route-projectId="@Model.ProjectId"
                   class="btn btn-primary">

                    <i class="bi bi-plus-lg"></i>
                    Add First Member

                </a>

            </div>
        }
        else
        {
            <div class="row">

                @foreach (var member in Model.Members)
                {
                    var initials = string.Join("",
                    member.EmployeeName
                    .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Take(2)
                    .Select(x => char.ToUpper(x[0])));
                    <div class="col-12 mb-3">

                        <div class="card tf-member-card border-0 shadow-sm mb-3">

                            <div class="card-body">

                                <div class="d-flex">

                                    <div class="tf-avatar me-3">
                                        @initials
                                    </div>

                                    <div class="flex-grow-1">

                                        <div class="d-flex justify-content-between align-items-start">

                                            <div>

                                                <h5 class="mb-1">
                                                    @member.EmployeeName
                                                </h5>

                                                <div class="tf-member-meta">
                                                    <i class="bi bi-envelope me-1"></i>
                                                    @member.Email
                                                </div>

                                            </div>

                                            @if (member.IsBillable)
                                            {
                                                <span class="badge bg-success">
                                                    Billable
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    Non-Billable
                                                </span>
                                            }

                                        </div>

                                        <div class="mt-3">
                                            <span class="badge bg-info text-dark">
                                                @member.ProjectRole
                                            </span>
                                        </div>

                                        <div class="row mt-3">

                                            <div class="col-md-4">

                                                <small class="text-muted d-block">
                                                    Capacity
                                                </small>

                                                @member.DailyCapacityHours hrs/day

                                            </div>

                                            <div class="col-md-4">

                                                <small class="text-muted d-block">
                                                    Allocation
                                                </small>

                                                @member.AllocationPercent%

                                            </div>

                                            <div class="col-md-4">

                                                <small class="text-muted d-block">
                                                    Joined
                                                </small>

                                                @member.JoinedDate.ToString("dd MMM yyyy")

                                            </div>

                                        </div>

                                        <div class="mt-4 text-end">

                                            <a asp-action="EditMember"
                                               asp-controller="Project"
                                               asp-route-id="@member.ProjectMemberId"
                                               class="btn btn-sm btn-outline-primary">

                                                <i class="bi bi-pencil"></i>
                                                Edit

                                            </a>

                                            <a asp-action="Delete"
                                               asp-controller="ProjectMember"
                                               asp-route-id="@member.ProjectMemberId"
                                               class="btn btn-sm btn-outline-danger">

                                                <i class="bi bi-trash"></i>
                                                Remove

                                            </a>

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }
    </div>

</div>