@model TaskFlow.ViewModels.Project.ProjectMemberFormVM

@{
    ViewData["Title"] = "Edit Project Member";
}

<div class="container">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-sm">

                <div class="card-header">

                    <h4 class="mb-0">
                        Edit Project Member
                    </h4>

                </div>

                <div class="card-body">

                    <form asp-action="EditMember" method="post">

                        <input asp-for="ProjectMemberId" type="hidden" />
                        <input asp-for="ProjectId" type="hidden" />
                        <input asp-for="EmployeeId" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">

                            <label class="form-label">Project</label>

                            <input class="form-control"
                                   value="@Model.ProjectName"
                                   readonly />

                        </div>

                        <div class="mb-3">

                            <label class="form-label">Employee</label>

                            <input class="form-control"
                                   value="@Model.EmployeeName"
                                   readonly />

                        </div>

                        <div class="mb-3">

                            <label asp-for="ProjectRoleId" class="form-label"></label>

                            <select asp-for="ProjectRoleId"
                                    asp-items="Model.ProjectRoles"
                                    class="form-select">
                                <option value="">Select Project Role</option>
                            </select>

                            <span asp-validation-for="ProjectRoleId" class="text-danger"></span>

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label asp-for="DailyCapacityHours" class="form-label"></label>

                                <input asp-for="DailyCapacityHours"
                                       class="form-control" />

                                <span asp-validation-for="DailyCapacityHours" class="text-danger"></span>

                            </div>

                            <div class="col-md-6 mb-3">

                                <label asp-for="AllocationPercent" class="form-label"></label>

                                <input asp-for="AllocationPercent"
                                       class="form-control" />

                                <span asp-validation-for="AllocationPercent" class="text-danger"></span>

                            </div>

                        </div>

                        <div class="mb-3 form-check">

                            <input asp-for="IsBillable"
                                   class="form-check-input" />

                            <label asp-for="IsBillable"
                                   class="form-check-label"></label>

                        </div>

                        <div class="mb-4">

                            <label asp-for="JoinedDate" class="form-label"></label>

                            <input asp-for="JoinedDate"
                                   type="date"
                                   class="form-control" />

                            <span asp-validation-for="JoinedDate" class="text-danger"></span>

                        </div>

                        <div class="d-flex justify-content-between">

                            <a asp-action="Details"
                               asp-route-id="@Model.ProjectId"
                               class="btn btn-outline-secondary">

                                Back

                            </a>

                            <button type="submit"
                                    class="btn btn-primary">

                                <i class="bi bi-check-circle"></i>

                                Update Member

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}