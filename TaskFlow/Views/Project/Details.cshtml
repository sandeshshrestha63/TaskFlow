@model TaskFlow.ViewModels.Project.ProjectDetailsVM

@{
    ViewData["Title"] = "Project Details";
}

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="mb-1">@Model.Name</h2>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="text-muted mb-0">
                    @Model.Description
                </p>
            }
        </div>

        <div class="d-flex gap-2">

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                Back
            </a>

            <a asp-action="Edit"
               asp-route-id="@Model.ProjectId"
               class="btn btn-primary">
                <i class="bi bi-pencil-square"></i>
                Edit Project
            </a>
            <a asp-action="Archive"
               asp-route-id="@Model.ProjectId"
               class="btn btn-sm btn-outline-danger">
                <i class="bi bi-archive"></i>
                Archive
            </a>
        </div>

    </div>

    <div class="row">

        <!-- General Information -->
        <div class="col-lg-6 mb-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        General Information
                    </h5>
                </div>

                <div class="card-body">

                    <table class="table table-borderless mb-0">

                        <tr>
                            <th style="width:40%">Status</th>
                            <td>@Model.StatusName</td>
                        </tr>

                        <tr>
                            <th>Priority</th>
                            <td>@Model.PriorityName</td>
                        </tr>

                        <tr>
                            <th>Created By</th>
                            <td>@Model.CreatedByName</td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

        <!-- Timeline -->
        <div class="col-lg-6 mb-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        Timeline
                    </h5>
                </div>

                <div class="card-body">

                    <table class="table table-borderless mb-0">

                        <tr>
                            <th style="width:40%">Start Date</th>
                            <td>@Model.StartDate.ToString("dd MMM yyyy")</td>
                        </tr>

                        <tr>
                            <th>Target End Date</th>
                            <td>
                                @(Model.TargetEndDate?.ToString("dd MMM yyyy") ?? "-")
                            </td>
                        </tr>

                        <tr>
                            <th>Created Date</th>
                            <td>@Model.CreatedDate.ToString("dd MMM yyyy")</td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

    </div>

    <!-- Placeholder for future modules -->
    <div class="card border-0 shadow-sm">

        <div class="card-header bg-white">
            <h5 class="mb-0">
                Upcoming Project Features
            </h5>
        </div>

        <div class="card-body">

            <div class="row text-center">

                <div class="col-md-2 mb-3">
                    <i class="bi bi-people fs-2 text-secondary"></i>
                    <div>Members</div>
                </div>

                <div class="col-md-2 mb-3">
                    <i class="bi bi-kanban fs-2 text-secondary"></i>
                    <div>Sprints</div>
                </div>

                <div class="col-md-2 mb-3">
                    <i class="bi bi-list-task fs-2 text-secondary"></i>
                    <div>Tasks</div>
                </div>

                <div class="col-md-2 mb-3">
                    <i class="bi bi-clock-history fs-2 text-secondary"></i>
                    <div>Activities</div>
                </div>

                <div class="col-md-2 mb-3">
                    <i class="bi bi-folder fs-2 text-secondary"></i>
                    <div>Files</div>
                </div>

                <div class="col-md-2 mb-3">
                    <i class="bi bi-bar-chart fs-2 text-secondary"></i>
                    <div>Reports</div>
                </div>

            </div>

        </div>

    </div>

</div>