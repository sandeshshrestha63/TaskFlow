@model TaskFlow.ViewModels.Project.ProjectDetailsVM

@{
    ViewData["Title"] = "Project Details";
}
<style>
    .tf-avatar {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background-color: #0d6efd;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .tf-member-card {
        transition: all .2s ease;
    }

        .tf-member-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.08);
        }

    .tf-member-meta {
        color: #6c757d;
        font-size: .9rem;
    }
</style>
<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="mb-1">@Model.Name</h2>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="text-muted mb-0">
                    @Model.Description
                </p>
            }
        </div>

        <div class="d-flex gap-2">

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                Back
            </a>

            <a asp-action="Edit"
               asp-route-id="@Model.ProjectId"
               class="btn btn-primary">
                <i class="bi bi-pencil-square"></i>
                Edit Project
            </a>
            <a asp-action="Archive"
               asp-route-id="@Model.ProjectId"
               class="btn btn-sm btn-outline-danger">
                <i class="bi bi-archive"></i>
                Archive
            </a>
        </div>

    </div>

    <div class="row">
        <!-- Project Overview -->
        <partial name="Partial/_ProjectOverview" model="Model" />
    </div>

    <partial name="Partial/_ProjectMembers"
             model="Model" />
</div>