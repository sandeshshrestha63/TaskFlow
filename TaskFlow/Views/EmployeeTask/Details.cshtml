@model TaskDetailsVM

<div class="container-fluid">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0">@Model.Title</h4>
                <small class="text-muted">
                    Task Details
                </small>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    Edit
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    Back
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <h6>Description</h6>
                    <div class="border rounded p-3 bg-light">
                        @(string.IsNullOrWhiteSpace(Model.Description)
                            ? "No description provided."
                            : Model.Description)
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border">
                        <div class="card-body">
                            <table class="table table-sm">
                                <tr>
                                    <th>Assigned To</th>
                                    <td>@Model.AssignedTo</td>
                                </tr>
                                <tr>
                                    <th>Created By</th>
                                    <td>@Model.CreatedBy</td>
                                </tr>
                                <tr>
                                    <th>Priority</th>
                                    <td>@Model.Priority</td>
                                </tr>
                                <tr>
                                    <th>Status</th>
                                    <td>@Model.Status</td>
                                </tr>
                                <tr>
                                    <th>Due Date</th>
                                    <td>
                                        @Model.DueDate?.ToString("dd MMM yyyy")
                                    </td>
                                </tr>
                                <tr>
                                    <th>Estimated Hrs</th>
                                    <td>@Model.EstimatedHours</td>
                                </tr>
                                <tr>
                                    <th>Actual Hrs</th>
                                    <td>@Model.ActualHours</td>
                                </tr>
                                <tr>
                                    <th>Created</th>
                                    <td>
                                        @Model.CreatedDate.ToString("dd MMM yyyy")
                                    </td>
                                </tr>
                                @if (Model.CompletedDate.HasValue)
                                {
                                    <tr>
                                        <th>Completed</th>
                                        <td>
                                            @Model.CompletedDate.Value.ToString("dd MMM yyyy")
                                        </td>
                                    </tr>
                                }
                            </table>
                        </div>
                    </div>
                    <div class="card mt-4">
                        <div class="card-header">
                            Update Status
                        </div>
                        <div class="card-body">
                            <form asp-action="UpdateStatus" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="TaskId" value="@Model.Id" />
                                <div class="row">
                                    <div class="col-md-8">
                                        <select name="StatusId" class="form-select">
                                            @foreach (var status in ViewBag.Statuses)
                                            {
                                                <option value="@status.Id">
                                                    @status.Name
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <button type="submit"
                                                class="btn btn-primary w-100">
                                            Update Status
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="card mt-4">

                        <div class="card-header">
                            Comments
                        </div>

                        <div class="card-body">

                            @if (Model.Comments.Any())
                            {
                                foreach (var comment in Model.Comments)
                                {
                                    <div class="border rounded p-3 mb-3">

                                        <div class="d-flex justify-content-between">

                                            <strong>
                                                @comment.EmployeeName
                                            </strong>

                                            <small class="text-muted">
                                                @comment.CreatedDate.ToString("dd MMM yyyy hh:mm tt")
                                            </small>

                                        </div>

                                        <div class="mt-2">
                                            @comment.Comment
                                        </div>

                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">
                                    No comments available.
                                </p>
                            }

                            <hr />

                            <form asp-action="AddComment"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="TaskId"
                                       value="@Model.Id" />

                                <div class="mb-3">

                                    <textarea name="Comment"
                                              rows="4"
                                              class="form-control"
                                              placeholder="Write comment..."></textarea>

                                </div>

                                <button type="submit"
                                        class="btn btn-success">
                                    Add Comment
                                </button>

                            </form>

                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>