@model List<TaskFlow.ViewModels.Dashboard.EmployeeTaskSummaryVM>

<div class="dashboard-card">

    <div class="dashboard-card-header">

        <div>
            <h5 class="dashboard-card-title">
                <i class="fa-solid fa-list-check text-danger me-2"></i>
                Tasks Requiring Attention
            </h5>

            <p class="dashboard-card-subtitle">
                Overdue and upcoming tasks
            </p>
        </div>

        <span class="tf-badge">
            @Model.Count
        </span>

    </div>

    <div class="dashboard-card-body p-0">

        @if (Model.Any())
        {
            @foreach (var task in Model.Take(5))
            {
                <a asp-controller="EmployeeTask"
                   asp-action="Details"
                   asp-route-id="@task.Id"
                   class="dashboard-list-link">

                    <div class="dashboard-list-item">

                        <div class="d-flex justify-content-between align-items-start">

                            <div class="flex-grow-1">

                                <div class="task-title">

                                    <span class="text-muted small me-1">
                                        #@task.Id
                                    </span>

                                    @task.Title

                                </div>

                                <div class="small text-muted mt-2">

                                    <div>

                                        <i class="fa-solid fa-user me-2"></i>

                                        @task.AssignedTo

                                    </div>

                                    @if (task.DueDate.HasValue)
                                    {
                                        <div class="mt-1">

                                            <i class="fa-regular fa-calendar me-2"></i>

                                            @if (task.IsOverdue)
                                            {
                                                <span class="text-danger">
                                                    Overdue by @Math.Abs(task.DaysRemaining) day(s)
                                                </span>
                                            }
                                            else if (task.DaysRemaining == 0)
                                            {
                                                <span class="text-warning">
                                                    Due Today
                                                </span>
                                            }
                                            else if (task.DaysRemaining == 1)
                                            {
                                                <span class="text-info">
                                                    Due Tomorrow
                                                </span>
                                            }
                                            else
                                            {
                                                <span>
                                                    Due in @task.DaysRemaining day(s)
                                                </span>
                                            }

                                        </div>
                                    }

                                </div>

                            </div>

                            <span class="tf-badge"
                                  style="background:@task.PriorityColor">

                                @task.Priority

                            </span>

                        </div>

                        <div class="mt-3 d-flex gap-2 flex-wrap">

                            <span class="tf-badge"
                                  style="background:@task.StatusColor">

                                @task.Status

                            </span>

                            @if (task.IsOverdue)
                            {
                                <span class="tf-badge badge-overdue">
                                    Overdue
                                </span>
                            }

                        </div>

                    </div>

                </a>
            }
        }
        else
        {
            <div class="empty-state">

                <div class="empty-state-icon">
                    <i class="fa-solid fa-circle-check"></i>
                </div>

                <div class="empty-state-title">
                    No Tasks Require Attention
                </div>

                <div class="empty-state-text">
                    All tasks are progressing as expected.
                </div>

            </div>
        }

    </div>

    <div class="dashboard-footer">

        <a asp-controller="EmployeeTask"
           asp-action="Index">

            View All Tasks (@Model.Count)

            <i class="fa-solid fa-arrow-right ms-1"></i>

        </a>

    </div>

</div>
