@model TaskFlow.ViewModels.Dashboard.EmployeeTaskSummaryVM?

@{
    string priorityClass = "badge-low";

    if (Model != null)
    {
        switch (Model.Priority?.ToLower())
        {
            case "high":
            case "critical":
                priorityClass = "badge-high";
                break;

            case "medium":
                priorityClass = "badge-medium";
                break;

            default:
                priorityClass = "badge-low";
                break;
        }
    }

    string statusClass = "badge-progress";

    if (Model != null)
    {
        switch (Model.Status?.ToLower())
        {
            case "completed":
                statusClass = "badge-completed";
                break;

            case "pending":
                statusClass = "badge-pending";
                break;

            case "overdue":
                statusClass = "badge-overdue";
                break;

            default:
                statusClass = "badge-progress";
                break;
        }
    }
}

<div class="dashboard-card focus-task-card h-100">

    <div class="dashboard-card-header">

        <div>

            <h5 class="dashboard-card-title mb-1">

                <i class="bi bi-stars text-warning me-2"></i>

                Focus Task

            </h5>

            <div class="dashboard-card-subtitle">

                Your highest priority task

            </div>

        </div>

        @if (Model != null && Model.IsOverdue)
        {
            <span class="tf-badge badge-overdue">

                <i class="bi bi-exclamation-circle me-1"></i>

                Needs Attention

            </span>
        }

    </div>

    <div class="dashboard-card-body">

        @if (Model == null)
        {
            <div class="empty-state">

                <div class="empty-state-icon">

                    <i class="bi bi-check2-all"></i>

                </div>

                <div class="empty-state-title">

                    You're all caught up!

                </div>

                <div class="empty-state-text">

                    Great work! There are currently no active tasks requiring your attention.

                </div>

            </div>
        }
        else
        {
            <div class="focus-task-header">

                <div>

                    <div class="focus-task-title">

                        @Model.Title

                    </div>

                    <div class="focus-task-description">

                        This task has been selected as your current priority. Complete it before moving on to lower priority work.

                    </div>

                </div>

            </div>

            <div class="focus-task-meta">

                <div class="focus-task-meta-item">

                    <i class="bi bi-person"></i>

                    <span>

                        @Model.AssignedBy

                    </span>

                </div>

                <div class="focus-task-meta-item">

                    <i class="bi bi-calendar-event"></i>

                    <span>

                        @if (Model.DueDate.HasValue)
                        {
                            @Model.DueDate.Value.ToString("dd MMM yyyy")
                        }
                        else
                        {
                            <text>No Due Date</text>
                        }

                    </span>

                </div>

            </div>

            <div class="d-flex flex-wrap gap-2 mb-4">

                <span class="tf-badge @priorityClass">

                    @Model.Priority

                </span>

                <span class="tf-badge @statusClass">

                    @Model.Status

                </span>

            </div>

            <div class="focus-task-footer">

                <div class="text-muted small">

                    Stay focused and complete this task before starting new work.

                </div>

                <a asp-controller="EmployeeTask"
                   asp-action="Details"
                   asp-route-id="@Model.Id"
                   class="tf-btn tf-btn-primary">

                    <i class="bi bi-box-arrow-up-right"></i>

                    Open Task

                </a>

            </div>

        }

    </div>

</div>