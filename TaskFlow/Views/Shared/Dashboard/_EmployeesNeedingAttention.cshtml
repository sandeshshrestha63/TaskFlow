@model List<TaskFlow.ViewModels.Dashboard.EmployeeAttentionVM>

<div class="dashboard-card">

    <div class="dashboard-card-header">

        <div>

            <h5 class="dashboard-card-title">
                <i class="fa-solid fa-users text-warning me-2"></i>
                Employees Needing Attention
            </h5>

            <p class="dashboard-card-subtitle">
                Team members requiring review
            </p>

        </div>

        <span class="tf-badge">
            @Model.Count
        </span>

    </div>

    <div class="dashboard-card-body p-0">

        @if (Model.Any())
        {
            @foreach (var employee in Model)
            {
                var workloadPercentage = employee.WorkloadLevel switch
                {
                    "Low" => 35,
                    "Medium" => 70,
                    "High" => 100,
                    _ => 0
                };

                <a asp-controller="EmployeeTask"
                   asp-action="Index"
                   asp-route-employeeId="@employee.EmployeeId"
                   asp-route-dashboardFilter="active"
                   class="dashboard-list-link">

                    <div class="dashboard-list-item">

                        <!-- Employee -->

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <div class="fw-semibold">

                                    @employee.EmployeeName

                                </div>

                                <small class="text-muted">

                                    @employee.ActiveTasks Active Tasks

                                </small>

                            </div>

                            <span class="tf-badge"
                                  style="background:@employee.WorkloadColor">

                                @employee.WorkloadLevel

                            </span>

                        </div>

                        <!-- Statistics -->

                        <div class="row text-center mt-3">

                            <div class="col">

                                <div class="fw-bold text-danger">

                                    @employee.OverdueTasks

                                </div>

                                <small class="text-muted">

                                    Overdue

                                </small>

                            </div>

                            <div class="col">

                                <div class="fw-bold text-primary">

                                    @employee.ActiveTasks

                                </div>

                                <small class="text-muted">

                                    Active

                                </small>

                            </div>

                            <div class="col">

                                <div class="fw-bold text-warning">

                                    @employee.DueTodayTasks

                                </div>

                                <small class="text-muted">

                                    Due Today

                                </small>

                            </div>

                        </div>

                        <!-- Workload -->

                        <div class="mt-3">

                            <div class="progress-label">

                                <span>Workload</span>

                                <span>@employee.WorkloadLevel</span>

                            </div>

                            <div class="tf-progress">

                                <div class="tf-progress-bar"
                                     style="width:@workloadPercentage%; background:@employee.WorkloadColor">
                                </div>

                            </div>

                        </div>

                    </div>

                </a>
            }
        }
        else
        {
            <div class="empty-state">

                <div class="empty-state-icon">

                    <i class="fa-solid fa-circle-check"></i>

                </div>

                <div class="empty-state-title">

                    Everyone is on track

                </div>

                <div class="empty-state-text">

                    No employees currently require attention.

                </div>

            </div>
        }

    </div>

    <div class="dashboard-footer">

        <a asp-controller="Employee"
           asp-action="Index">

            Manage Employees

            <i class="fa-solid fa-arrow-right ms-1"></i>

        </a>

    </div>

</div>