@model List<TaskFlow.ViewModels.Dashboard.UpcomingDeadlineVM>

<div class="dashboard-card">

    <div class="dashboard-card-header">

        <div>

            <h5 class="dashboard-card-title">
                <i class="fa-solid fa-calendar-days text-primary me-2"></i>
                Upcoming Deadlines
            </h5>

            <p class="dashboard-card-subtitle">
                Tasks due in the coming days
            </p>

        </div>

        <span class="tf-badge">
            @Model.Count
        </span>

    </div>

    <div class="dashboard-card-body p-0">

        @if (Model.Any())
        {
            @foreach (var task in Model)
            {
                <a asp-controller="EmployeeTask"
                   asp-action="Details"
                   asp-route-id="@task.TaskId"
                   class="dashboard-list-link">

                    <div class="dashboard-list-item">

                        <div class="px-3 py-3">

                            <div class="d-flex justify-content-between">

                                <div>

                                    <div class="task-title">

                                        @task.Title

                                    </div>

                                    <div class="small text-muted mt-1">

                                        <i class="fa-solid fa-user me-1"></i>

                                        @task.AssignedTo

                                    </div>

                                </div>

                                <span class="tf-badge"
                                      style="background:@task.PriorityColor">

                                    @task.Priority

                                </span>

                            </div>

                            <div class="mt-2">

                                <span class="deadline-pill">

                                    @task.DueLabel

                                </span>

                            </div>

                        </div>

                    </div>

                </a>
            }
        }
        else
        {
            <div class="empty-state">

                <div class="empty-state-icon">

                    <i class="fa-solid fa-calendar-check"></i>

                </div>

                <div class="empty-state-title">

                    No upcoming deadlines

                </div>

                <div class="empty-state-text">

                    You're all caught up.

                </div>

            </div>
        }

    </div>

    <div class="dashboard-footer">

        <a asp-controller="EmployeeTask"
           asp-action="Index">

            Manage Tasks

            <i class="fa-solid fa-arrow-right ms-1"></i>

        </a>

    </div>

</div>