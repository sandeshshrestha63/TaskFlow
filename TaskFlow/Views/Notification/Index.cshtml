@using TaskFlow.Helpers
@model List<TaskFlow.DTOs.Notification.NotificationResponse>

@{
    ViewData["Title"] = "Notifications";
}
@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}
<div class="dashboard-card">

    <div class="dashboard-card-header d-flex justify-content-between align-items-center">

        <div>
            <h4 class="dashboard-card-title mb-1">
                <i class="fas fa-bell me-2 text-warning"></i>
                Notifications
            </h4>

            <p class="text-muted mb-0">
                View and manage your notifications.
            </p>
        </div>

        @if (Model.Any(x => !x.IsRead))
        {
            <button id="btnMarkAllRead"
                    class="btn btn-outline-primary">
                <i class="fas fa-check-double me-2"></i>
                Mark All Read
            </button>
        }

    </div>

    <div class="dashboard-card-body p-0">

        @if (!Model.Any())
        {
            <div class="text-center py-5">

                <i class="fas fa-bell-slash fa-3x text-muted mb-3"></i>

                <h5>No Notifications</h5>

                <p class="text-muted mb-0">
                    You're all caught up.
                </p>

            </div>
        }
        else
        {
            @foreach (var notification in Model)
            {
                <a asp-action="Open"
                   asp-route-id="@notification.NotificationId"
                   class="notification-item @(notification.IsRead ? "" : "unread") text-decoration-none text-dark">

                    <div class="">

                        <strong>
                            @notification.Title<br/>
                        <small class="text-muted">
                            @TimeAgoHelper.GetRelativeTime(notification.CreatedDate)
                        </small>
                        </strong>


                    </div>

                    <div class="notification-message mt-2">
                        @notification.Message
                    </div>

                </a>
            }
        }

    </div>

</div>
@section Scripts
{
    <script>

        $("#btnMarkAllRead").click(function () {

            $.post("/Notification/MarkAllAsRead", function () {

                location.reload();

            });

        });

    </script>
}